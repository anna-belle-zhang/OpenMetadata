# Local dev environment — WSL2 native OM server
# Usage: source conf/local-dev.env

# PostgreSQL (native WSL2)
export DB_DRIVER_CLASS=org.postgresql.Driver
export DB_SCHEME=postgresql
export DB_USER=openmetadata_user
export DB_USER_PASSWORD=openmetadata_password
export DB_HOST=localhost
export DB_PORT=5432
export OM_DATABASE=openmetadata_db
export DB_PARAMS="allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC"

# OpenSearch (Docker)
export ELASTICSEARCH_HOST=localhost
export ELASTICSEARCH_PORT=9200
export ELASTICSEARCH_SCHEME=http
export SEARCH_TYPE=opensearch
export ELASTICSEARCH_USER=
export ELASTICSEARCH_PASSWORD=

# Airflow (Docker local)
export PIPELINE_SERVICE_CLIENT_ENDPOINT=http://localhost:8080
export AIRFLOW_USERNAME=admin
export AIRFLOW_PASSWORD=admin
export PIPELINE_SERVICE_CLIENT_VERIFY_SSL=no-ssl

# Server
export SERVER_PORT=8585
export SERVER_ADMIN_PORT=8586
export LOG_LEVEL=INFO
export OPENMETADATA_HEAP_OPTS="-Xmx2G -Xms1G"

# Auth (basic auth, dev defaults)
export AUTHENTICATION_PROVIDER=basic
export AUTHORIZER_CLASS_NAME=org.openmetadata.service.security.DefaultAuthorizer
export AUTHORIZER_REQUEST_FILTER=org.openmetadata.service.security.JwtFilter
export AUTHORIZER_ADMIN_PRINCIPALS=[admin]
export AUTHORIZER_ALLOWED_REGISTRATION_DOMAIN='["all"]'
export AUTHORIZER_INGESTION_PRINCIPALS=[ingestion-bot]
export AUTHORIZER_PRINCIPAL_DOMAIN=open-metadata.org
export AUTHENTICATION_PUBLIC_KEYS=[http://localhost:8585/api/v1/system/config/jwks]
export AUTHENTICATION_AUTHORITY=https://accounts.google.com
export AUTHENTICATION_ENABLE_SELF_SIGNUP=true
export JWT_ISSUER=open-metadata.org
export JWT_KEY_ID=Gb389a-9f76-gdjs-a92j-0242bk94356
export RSA_PUBLIC_KEY_FILE_PATH=./conf/public_key.der
export RSA_PRIVATE_KEY_FILE_PATH=./conf/private_key.der
